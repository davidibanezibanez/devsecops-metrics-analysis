author = {Whalen, Michael W. and Godefroid, Patrice and Mariani, Leonardo and Polini, Andrea and Tillmann, Nikolai and Visser, Willem},
title = {FITE: future integrated testing environment},
year = {2010},
isbn = {9781450304276},
